# backend/.env  — Copy this file, fill in values, NEVER commit to git
# Add these same vars in Netlify → Site Settings → Environment Variables

DATABASE_URL=postgresql://user:password@host:5432/vibekit?sslmode=require
JWT_SECRET=replace-with-node-e-require-crypto-randomBytes-64-toString-hex
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email (optional — contact form still saves to DB without these)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="VibeKit Studio" <noreply@yourdomain.com>
